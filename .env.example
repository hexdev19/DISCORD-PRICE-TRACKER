APP_ENV=dev
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/pricetracker
REDIS_URL=redis://localhost:6379/0


DISCORD_TOKEN=
DISCORD_CLIENT_ID=
