# --- Core ---
APP_ENV=dev                                  # dev | staging | prod | test
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR

# --- Datastores ---
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/pricetracker
REDIS_URL=redis://localhost:6379/0

# --- Discord ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Auth / crypto ---
SESSION_COOKIE_SECRET=                       # >= 32 bytes random
OAUTH_TOKEN_ENC_KEY=                         # 32-byte url-safe base64 for Fernet

# --- Dashboard (Next.js) ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# --- Observability (optional in dev; required in prod) ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
RELEASE_SHA=

# --- Future ---
PROXY_URL=                                   # reserved; no-op at MVP
